# 应用
SECRET_KEY=your-secret-key-at-least-32-chars
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30
ENVIRONMENT=development

# 平台自身对外可访问的基础 URL（Worker 回传 webhook 使用）
# 一键部署 Worker 时必须改成公网 HTTPS 地址；localhost/http 仅用于本地开发
# 本地开发：http://localhost:8000
# 生产：https://your-domain.com
APP_BASE_URL=http://localhost:8000

# 数据库
DATABASE_URL=sqlite+aiosqlite:///./cf_email.db
# SQLite 部署可置 true：应用启动时自动执行 alembic upgrade head
AUTO_MIGRATE_SQLITE=false

# Cloudflare
CF_API_BASE_URL=https://api.cloudflare.com/client/v4
CF_WEBHOOK_SECRET=your-webhook-secret-here

# 平台管理员（首次启动自动创建）
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-on-first-run

# 应用
APP_NAME=CF Email Manager
APP_VERSION=0.1.0
DEBUG=false

# 前端会话 Cookie 是否仅限 HTTPS（生产环境置 true）
COOKIE_SECURE=false

# Web 表单 CSRF 防护（生产环境必须保持 true）
CSRF_PROTECTION=true

# 安全限制（单进程内存限流，适合自托管单实例）
TRUST_PROXY_HEADERS=false
TRUSTED_PROXY_IPS=
LOGIN_RATE_LIMIT_ATTEMPTS=5
LOGIN_RATE_LIMIT_WINDOW_SECONDS=300
API_KEY_RATE_LIMIT_ATTEMPTS=120
API_KEY_RATE_LIMIT_WINDOW_SECONDS=60
PUBLIC_MAIL_RATE_LIMIT_ATTEMPTS=60
PUBLIC_MAIL_RATE_LIMIT_WINDOW_SECONDS=60
PUBLIC_MAIL_SEND_RATE_LIMIT_ATTEMPTS=10
PUBLIC_MAIL_SEND_RATE_LIMIT_WINDOW_SECONDS=60
WEBHOOK_MAX_BYTES=1048576
